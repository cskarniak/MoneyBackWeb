[Unit]
Description=MoneyBack API (NestJS)
After=network.target postgresql.service

[Service]
Type=simple
User=christian
WorkingDirectory=/home/christian/moneyback
ExecStart=/usr/local/bin/node /home/christian/moneyback/apps/api/dist/src/main.js
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
